---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('publicaciones');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const related = (await getCollection('publicaciones'))
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout
  title={post.data.title}
  description={post.data.description ?? post.data.title}
  image={post.data.image ?? '/images/logo.png'}
  type="article"
>
  <!-- Banner image or color block -->
  <section class="relative flex items-end pb-0" style="min-height:35vh;background-color:#1C1F39;">
    {post.data.image && (
      <img
        src={post.data.image}
        alt={post.data.imageAlt ?? post.data.title}
        class="absolute inset-0 w-full h-full object-cover opacity-40"
      />
    )}
    <div class="relative z-10 em-container pb-8 pt-16">
      {post.data.category && (
        <p class="text-xs font-semibold uppercase tracking-widest mb-3 font-['Montserrat']" style="color:#CBD1BA;">{post.data.category}</p>
      )}
      <h1 class="font-['Cinzel'] text-2xl md:text-4xl font-bold text-white leading-tight max-w-3xl">{post.data.title}</h1>
      <p class="text-sm mt-3 font-['Montserrat'] opacity-70 text-white">
        {new Date(post.data.date).toLocaleDateString('es-DO', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </div>
  </section>

  <!-- Article content -->
  <article class="em-container py-12 max-w-3xl">
    <div class="prose-em">
      <Content />
    </div>
    <div class="mt-10 pt-6 border-t border-gray-200">
      <a href="/publicaciones/" class="text-sm font-semibold font-['Montserrat'] hover:opacity-70 transition-opacity flex items-center gap-2" style="color:#1C1F39;">
        ← Volver a publicaciones
      </a>
    </div>
  </article>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="py-12" style="background-color:#e9e9e9;">
      <div class="em-container">
        <div class="flex items-center mb-8">
          <span class="block w-8 h-px bg-[#CBD1BA]"></span>
          <h2 class="mx-4 text-sm font-['Cinzel'] font-semibold tracking-widest uppercase">También te puede interesar</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {related.map((p) => (
            <a href={`/publicaciones/${p.id}/`} class="block group bg-white hover:shadow-lg transition-shadow duration-200 overflow-hidden">
              {p.data.image && (
                <div class="overflow-hidden h-40">
                  <img src={p.data.image} alt={p.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                </div>
              )}
              <div class="p-4">
                <h3 class="font-['Cinzel'] text-xs font-semibold leading-snug line-clamp-3" style="color:#1C1F39;">{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
