---

<Layout
  title="Nuestro Equipo"
  description="Conoce al equipo de EM Estrategia: profesionales de alto perfil en legal, finanzas, comunicación, sostenibilidad y estrategia internacional."
>
  <!-- Banner -->
  <section class="relative flex items-center justify-center" style="min-height:45vh;background-color:#1C1F39;">
    <img src="/images/BANNER_NUESTROS-PILARES.png" alt="Nuestros Pilares" class="absolute inset-0 w-full h-full object-cover opacity-50" />
    <h1 class="relative z-10 font-['Cinzel'] text-3xl md:text-5xl font-bold text-center tracking-widest" style="color:#CBD1BA;">
      NUESTROS PILARES
    </h1>
  </section>

  <!-- 4 Pilares -->
  <div id="valores" class="em-container -mt-10 relative z-20">
    <div class="grid grid-cols-2 md:grid-cols-4">
      {pilares.map(({ icon, title, text, bg }) => (
        <div class="p-6 text-center text-white" style={`background-color:${bg};`}>
          <img src={icon} alt={title} class="w-20 h-20 mx-auto mb-4 object-contain" />
          <h3 class="font-['Cinzel'] text-xs font-semibold mb-3" style="color:#CBD1BA;">{title}</h3>
          <p class="text-xs leading-relaxed opacity-85">{text}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Team members -->
  <section id="nuestro-equipo" class="py-6">
    {team.map((member, i) => (
      <div class={`py-10 ${i % 2 !== 0 ? '' : 'bg-white'}`} style={i % 2 !== 0 ? 'background-color:#f3f3f3;' : ''}>
        <div class="em-container grid grid-cols-1 md:grid-cols-3 gap-0 md:gap-8 items-start">

          <!-- Photo -->
          <div class={`${member.photoLeft ? 'md:order-1' : 'md:order-2'} mb-6 md:mb-0`}>
            <div class="team-photo-wrap">
              <img
                src={member.image}
                alt={member.name}
                class="w-full object-cover object-top relative z-10"
                style="max-height:420px;"
              />
            </div>
          </div>

          <!-- Text -->
          <div class={`md:col-span-2 px-2 md:px-0 ${member.photoLeft ? 'md:order-2' : 'md:order-1'}`}>

            <h2 class="font-['Cinzel'] text-xl font-bold mb-1 flex items-center gap-2" style="color:#9B7B72;">
              <span style="color:#CBD1BA;">◆</span>
              <span set:html={member.name} />
            </h2>
            <p class="font-['Montserrat'] text-sm font-bold mb-0.5" style="color:#1C1F39;">{member.role}</p>
            <a href={`mailto:${member.email}`} class="text-xs font-['Montserrat'] hover:opacity-70 block mb-4" style="color:#555;">
              {member.email}
            </a>

            <p class="font-['Cinzel'] text-sm font-bold mb-3 uppercase leading-snug" style="color:#1C1F39;">
              <strong set:html={member.intro} />
            </p>

            <div class="text-sm leading-relaxed text-justify font-['Montserrat'] mb-5 text-gray-700" set:html={member.bio} />

            <!-- Accordion -->
            {member.accordion.length > 0 && (
              <div class="accordion space-y-0">
                {member.accordion.map((section) => (
                  <div class="accordion-item border-b border-gray-200">
                    <button
                      class="accordion-btn w-full flex items-center justify-between py-3 px-1 text-left text-xs font-semibold font-['Montserrat'] hover:opacity-70 transition-opacity"
                      style="color:#1C1F39;"
                      aria-expanded="false"
                    >
                      <span>{section.title}</span>
                      <span class="accordion-icon ml-2 flex-shrink-0 text-lg leading-none transition-transform duration-200" style="color:#CBD1BA;">›</span>
                    </button>
                    <div class="accordion-content hidden px-2 pb-4 text-xs leading-relaxed text-gray-600 font-['Montserrat']" set:html={section.content} />
                  </div>
                ))}
              </div>
            )}
          </div>

        </div>
      </div>
    ))}
  </section>
</Layout>

<style>
  .accordion-btn[aria-expanded="true"] .accordion-icon {
    transform: rotate(90deg);
  }

  .team-photo-wrap {
    position: relative;
    display: inline-block;
    width: 100%;
  }
</style>

<script>
  document.querySelectorAll('.accordion-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.accordion-item') as HTMLElement;
      const content = item.querySelector('.accordion-content') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      content.classList.toggle('hidden', isOpen);
    });
  });
</script>
