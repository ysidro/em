---
import Layout from '../layouts/Layout.astro';
import ServiceFlipCard from '../components/ServiceFlipCard.astro';
import { getCollection, render } from 'astro:content';

const posts = (await getCollection('publicaciones'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const servicios = (await getCollection('servicios'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const serviciosRendered = await Promise.all(
  servicios.map(async (s) => {
    const { Content } = await render(s);
    return { s, Content };
  })
);
---

<Layout
  title="EM Estrategia y Soluciones"
  description="Somos un socio de confianza que comparte su visión y objetivos. Estrategia, legal, sostenibilidad y asuntos públicos en República Dominicana."
>
  <!-- Hero Banner -->
  <section class="relative flex items-center justify-center" style="min-height:45vh;background-color:#1C1F39;">
    <img
      src="/images/BANNER_PORTADA.png"
      alt="EM Estrategia Banner"
      class="absolute inset-0 w-full h-full object-cover opacity-50"
    />
    <div class="relative z-10 text-center px-4">
      <p class="text-sm uppercase tracking-[0.3em] font-semibold mb-2 font-['Montserrat']" style="color:#CBD1BA;">Estrategia &amp; Soluciones</p>
      <h1 class="text-white font-['Cinzel'] text-5xl md:text-7xl font-bold leading-tight">EM</h1>
      <p class="text-lg md:text-2xl font-bold mt-2 font-['Montserrat']" style="color:#CBD1BA;">ESTRATEGIA Y SOLUCIONES</p>
    </div>
  </section>

  <!-- Title separator -->
  <div class="flex items-center justify-center py-6 px-4" style="background-color:#CBD1BA;">
    <span class="block w-10 h-px bg-black"></span>
    <h2 class="mx-4 text-sm font-['Cinzel'] font-semibold tracking-widest uppercase">¿Por qué nosotros?</h2>
    <span class="block w-10 h-px bg-black"></span>
  </div>

  <!-- About section -->
  <section id="about" class="em-container py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0">
      <div class="p-6 text-justify border-r border-[#CBD1BA]">
        <p class="font-bold leading-relaxed">
          <strong>Nuestra trayectoria</strong> marca el compromiso con el éxito sostenible mediante la aplicación de principios éticos.
        </p>
      </div>
      <div class="p-6 text-justify border-r border-[#CBD1BA]">
        <p class="leading-relaxed">
          Partimos de la premisa de que una estrategia efectiva <strong>puede revolucionar una empresa</strong> y abrir las puertas a nuevas oportunidades.
        </p>
      </div>
      <div class="p-6 text-justify">
        <p class="font-bold leading-relaxed">
          <strong>Somos un socio de confianza</strong> que comparte su visión y objetivos. Una <strong>estrategia efectiva revoluciona</strong> y abre las puertas a nuevas oportunidades ¿Tu empresa está preparada?
        </p>
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="py-16" style="background-color:#e9e9e9;">
    <div class="flex items-center justify-center mb-10 px-4">
      <span class="block w-10 h-px bg-[#CBD1BA]"></span>
      <h2 class="mx-4 text-sm font-['Cinzel'] font-semibold tracking-widest uppercase">Nuestros Valores</h2>
      <span class="block w-10 h-px bg-[#CBD1BA]"></span>
    </div>
    <div class="em-container grid grid-cols-1 md:grid-cols-3 gap-0">
      {[
        { icon: '/images/Compromiso.png', title: 'Compromiso con la Excelencia', text: 'Buscamos la excelencia en cada aspecto de nuestro trabajo, esforzándonos por superar las expectativas de nuestros clientes.' },
        { icon: '/images/legal.png', title: 'Integridad y Ética', text: 'Operamos con los más altos estándares éticos. La transparencia y la honestidad son los pilares fundamentales de nuestra firma.' },
        { icon: '/images/colaboracion.png', title: 'Colaboración', text: 'Trabajamos en estrecha colaboración con nuestros clientes para entender y abordar sus desafíos únicos.' },
      ].map(({ icon, title, text }) => (
        <div class="p-8 text-center text-white" style="background-color:#1C1F39;">
          <img src={icon} alt={title} class="w-16 h-16 mx-auto mb-4 object-contain" />
          <h3 class="font-['Cinzel'] text-sm font-semibold mb-3" style="color:#CBD1BA;">{title}</h3>
          <p class="text-xs leading-relaxed opacity-90">{text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ SERVICIOS — flip cards sobre banner ═══ -->
  <section class="relative py-20">
    <!-- Background image -->
    <img
      src="/images/BANNER_NUESTROS-SERVICIOS.png"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
    />
    <!-- Overlay -->
    <div class="absolute inset-0" style="background:rgba(28,31,57,0.82);"></div>

    <div class="relative z-10">
      <!-- Section title with diamond -->
      <div class="flex flex-col items-center mb-12 px-4">
        <img src="/images/diamante.png" alt="" class="w-5 mb-4" />
        <div class="flex items-center gap-4">
          <span class="block w-12 h-px" style="background:#CBD1BA;"></span>
          <h2 class="font-['Cinzel'] text-2xl md:text-3xl font-bold text-white">
            <span class="px-3 py-1" style="background:rgba(203,209,186,0.15);">Nuestros Servicios</span>
          </h2>
          <span class="block w-12 h-px" style="background:#CBD1BA;"></span>
        </div>
      </div>

      <!-- Cards grid -->
      <div class="em-container grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {serviciosRendered.map(({ s }) => (
          <ServiceFlipCard
            id={s.id}
            title={s.data.title}
            icon={s.data.icon}
            items={s.data.items ?? []}
          />
        ))}
      </div>

      <!-- Modal content rendered server-side, copied into each dialog by script -->
      <div class="hidden" aria-hidden="true">
        {serviciosRendered.map(({ s, Content }) => (
          <div id={`modal-src-${s.id}`}>
            <Content />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest posts -->
  {posts.length > 0 && (
    <section class="py-16" style="background-color:#e9e9e9;">
      <div class="flex items-center justify-center mb-10 px-4">
        <span class="block w-10 h-px bg-[#CBD1BA]"></span>
        <h2 class="mx-4 text-sm font-['Cinzel'] font-semibold tracking-widest uppercase">Últimas Publicaciones</h2>
        <span class="block w-10 h-px bg-[#CBD1BA]"></span>
      </div>
      <div class="em-container grid grid-cols-1 md:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={`/publicaciones/${post.id}/`} class="block group bg-white hover:shadow-lg transition-shadow duration-200 overflow-hidden">
            {post.data.image ? (
              <div class="overflow-hidden h-48">
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt ?? post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            ) : (
              <div class="h-48 flex items-center justify-center" style="background-color:#1C1F39;">
                <span class="text-3xl font-['Cinzel'] font-bold" style="color:#CBD1BA;">EM</span>
              </div>
            )}
            <div class="p-4">
              <p class="text-xs font-semibold uppercase tracking-widest mb-1 font-['Montserrat']" style="color:#CBD1BA;">
                {post.data.category ?? 'Publicaciones'}
              </p>
              <h3 class="font-['Cinzel'] text-sm font-semibold leading-snug line-clamp-3" style="color:#1C1F39;">{post.data.title}</h3>
              <p class="text-xs text-gray-500 mt-2 font-['Montserrat']">
                {new Date(post.data.date).toLocaleDateString('es-DO', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/publicaciones/" class="btn-primary">Ver todas las publicaciones</a>
      </div>
    </section>
  )}
</Layout>

<script>
  // Copy server-rendered service content into each dialog body
  document.querySelectorAll('[id^="modal-src-"]').forEach((src) => {
    const id = src.id.replace('modal-src-', '');
    const body = document.getElementById(`modal-body-${id}`);
    if (body) body.innerHTML = src.innerHTML;
  });

  // Close dialog when clicking the backdrop (outside the dialog panel)
  document.querySelectorAll('dialog[id^="dialog-"]').forEach((el) => {
    const dialog = el as HTMLDialogElement;
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>
